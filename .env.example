# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.

# Supabase project URL — find it at: Supabase Dashboard > Project Settings > API > Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key — Dashboard > Project Settings > API > Project API keys > anon/public
# This key is safe to expose to the browser (RLS policies enforce access).
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional — Cloudflare Turnstile site key for the Coffee Chat Network apply form.
# When set, a CAPTCHA widget renders before submission. Leave blank to disable.
# Sign up free at https://dash.cloudflare.com/?to=/:account/turnstile
# Server-side verification (recommended) requires a Supabase edge function with the secret key.
VITE_TURNSTILE_SITE_KEY=
